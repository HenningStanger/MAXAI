# --- Lokal utvikling (Docker): se docker-compose.yml, deretter: docker compose up -d
# DATABASE_URL="postgresql://maxai:maxai_dev_local@127.0.0.1:5433/maxai"
# DIRECT_URL="postgresql://maxai:maxai_dev_local@127.0.0.1:5433/maxai"

# --- Produksjon (Neon / Vercel): Pooled + Direct
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="put-bcrypt-hash-here"
AUTH_SECRET="use-a-long-random-secret"
AUTH_COOKIE_SECURE="false"
MCP_CRON_SECRET="optional-secret-for-cron-endpoint"
RESEND_API_KEY="optional-resend-api-key-for-alerts"
LEAD_ALERT_FROM="MAXAI <onboarding@resend.dev>"
LEAD_ALERT_TO="owner@example.com"
