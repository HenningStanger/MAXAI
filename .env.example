# Neon/Supabase/Vercel Postgres (påkrevd). Eksempel Neon:
# postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="put-bcrypt-hash-here"
AUTH_SECRET="use-a-long-random-secret"
AUTH_COOKIE_SECURE="false"
MCP_CRON_SECRET="optional-secret-for-cron-endpoint"
RESEND_API_KEY="optional-resend-api-key-for-alerts"
LEAD_ALERT_FROM="MAXAI <onboarding@resend.dev>"
LEAD_ALERT_TO="owner@example.com"
